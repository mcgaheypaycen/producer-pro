# Frontend (Vite) — safe to expose in the browser
VITE_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# ---------------------------------------------------------------------------
# Supabase Edge Function secrets — set with `supabase secrets set KEY=value`,
# NOT in this file. Listed here for reference only.
# ---------------------------------------------------------------------------
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...        (from the Stripe webhook endpoint)
# STRIPE_PRICE_ID=price_...              (the subscription plan price)
# TRIAL_DAYS=14                          (0 disables the free trial)
# SITE_URL=https://your-app.vercel.app   (checkout/portal return URL)
# GOOGLE_CLIENT_ID=...                   (same OAuth client used in Supabase Auth)
# GOOGLE_CLIENT_SECRET=...
